# Taxi Trip Duration Predictor – Environment Variables Template
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql://taxi:YOUR_DB_PASSWORD@db:5432/taxi_eta

# JWT Auth
SECRET_KEY=YOUR_SECRET_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ML Model
MODEL_PATH=/app/models/active_model.pkl

# App
DEBUG=false
